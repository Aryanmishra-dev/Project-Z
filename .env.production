# Production Environment Configuration Template
# Copy to .env and fill in production values

# ===========================================
# ENVIRONMENT
# ===========================================
NODE_ENV=production

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
DATABASE_URL=postgresql://pdfquiz:YOUR_SECURE_PASSWORD@localhost:5432/pdfquiz_prod
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ===========================================
# REDIS - Caching & Queues
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# ===========================================
# JWT - Authentication
# Generate with: openssl rand -base64 64
# ===========================================
JWT_SECRET=GENERATE_A_SECURE_64_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_SECURE_64_CHAR_SECRET_HERE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# API SERVER
# ===========================================
API_PORT=3000
API_URL=https://your-domain.com/api

# ===========================================
# FRONTEND
# ===========================================
FRONTEND_PORT=5173
FRONTEND_URL=https://your-domain.com

# ===========================================
# NLP SERVICE - Quiz Generation
# ===========================================
NLP_SERVICE_PORT=8000
NLP_SERVICE_URL=http://localhost:8000

# ===========================================
# OLLAMA - Local LLM
# ===========================================
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# ===========================================
# OPENROUTER - Cloud LLM Fallback (Optional)
# ===========================================
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free

# ===========================================
# FILE UPLOAD
# ===========================================
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=/opt/apps/pdfquiz/uploads

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FILE_PATH=/opt/apps/pdfquiz/logs

# ===========================================
# SECURITY
# ===========================================
CORS_ORIGIN=https://your-domain.com
SESSION_SECRET=GENERATE_A_SECURE_SESSION_SECRET_HERE

# ===========================================
# MONITORING
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ===========================================
# EMAIL (Optional - for password reset)
# ===========================================
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASS=YOUR_SMTP_PASSWORD
EMAIL_FROM=noreply@your-domain.com
